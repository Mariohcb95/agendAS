<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AgendAS"
             xmlns:converters="clr-namespace:AgendAS.Converters"
             x:Class="AgendAS.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Conversores Globais -->
            <converters:StatusParaCorConverter x:Key="StatusParaCor" />
            <converters:StatusParaTextoConverter x:Key="StatusParaTexto" />
            <converters:InversoBooleanConverter x:Key="InversoBooleanConverter" />
            <converters:DataParaTextoConverter x:Key="DataParaTexto" />
            <converters:StringPreenchidaParaBooleanConverter x:Key="StringPreenchidaParaBoolean" />
            <converters:BooleanParaCorConverter x:Key="BooleanParaCor" />

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Themes/Cores.xaml" />
                <ResourceDictionary Source="Themes/Tipografia.xaml" />
                <ResourceDictionary Source="Themes/Dimensoes.xaml" />
                <ResourceDictionary Source="Themes/Estilos.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
