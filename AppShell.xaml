<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AgendAS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AgendAS"
    xmlns:views="clr-namespace:AgendAS.Views"
    Title="AgendAS"
    FlyoutBehavior="Flyout"
    FlyoutWidth="260"
    FlyoutBackgroundColor="{DynamicResource CardFundoCor}">

    <!-- Customização de Cores e Estilos Globais do Shell -->
    <Shell.Resources>
        <ResourceDictionary>
            <Style x:Key="BaseShellItemStyle" TargetType="Element">
                <Setter Property="Shell.BackgroundColor" Value="{DynamicResource AzulEscuroPrimario}" />
                <Setter Property="Shell.ForegroundColor" Value="White" />
                <Setter Property="Shell.TitleColor" Value="White" />
                <Setter Property="Shell.UnselectedColor" Value="{DynamicResource TextoTerciarioCor}" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <!-- Página de Login (Fora da navegação do menu Flyout) -->
    <ShellContent
        Title="Entrar"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        FlyoutItemIsVisible="False" />

    <!-- Área de Menu Executivo Flyout (Menu Hambúrguer) -->
    <FlyoutItem Title="Dashboard" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe871;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem Title="Agenda" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe8df;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:AgendaPage}"
            Route="AgendaPage" />
    </FlyoutItem>

    <FlyoutItem Title="Kanban" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe8f4;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:KanbanPage}"
            Route="KanbanPage" />
    </FlyoutItem>

    <FlyoutItem Title="Clientes" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe7ef;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:ClientesPage}"
            Route="ClientesPage" />
    </FlyoutItem>

    <FlyoutItem Title="Aplicadores" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe7fd;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:AplicadoresPage}"
            Route="AplicadoresPage" />
    </FlyoutItem>

    <FlyoutItem Title="Meu Perfil" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe853;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:PerfilPage}"
            Route="PerfilPage" />
    </FlyoutItem>

    <FlyoutItem Title="Configurações" Style="{StaticResource BaseShellItemStyle}">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="&#xe8b8;" FontFamily="MaterialIcons" Size="22" Color="{DynamicResource AzulClaro}" />
        </FlyoutItem.Icon>
        <ShellContent
            ContentTemplate="{DataTemplate views:ConfiguracoesPage}"
            Route="ConfiguracoesPage" />
    </FlyoutItem>

</Shell>
