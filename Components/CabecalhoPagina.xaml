<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgendAS.Components.CabecalhoPagina"
             x:Name="this">

    <VerticalStackLayout Spacing="2" Margin="0,0,0,16">
        <Label Text="{Binding Titulo, Source={x:Reference this}}"
               Style="{StaticResource LabelTituloGrande}"
               TextColor="{DynamicResource TextoPrimarioCor}" />
        
        <Label Text="{Binding Subtitulo, Source={x:Reference this}}"
               Style="{StaticResource LabelCorpo}"
               TextColor="{DynamicResource TextoTerciarioCor}"
               IsVisible="{Binding Subtitulo, Source={x:Reference this}, Converter={StaticResource StringPreenchidaParaBoolean}}" />
    </VerticalStackLayout>
</ContentView>
