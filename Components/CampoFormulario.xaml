<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgendAS.Components.CampoFormulario"
             x:Name="this">

    <VerticalStackLayout Spacing="4" Margin="0,0,0,16">
        <!-- Título do Campo -->
        <Label Text="{Binding Titulo, Source={x:Reference this}}"
               Style="{StaticResource LabelSecundario}"
               FontFamily="{StaticResource FonteSemibold}"
               TextColor="{DynamicResource TextoSecundarioCor}" />

        <!-- Container do Input Customizado -->
        <Border StrokeShape="RoundRectangle 8"
                StrokeThickness="1"
                Stroke="{Binding TemErro, Source={x:Reference this}, Converter={StaticResource BooleanParaCor}}"
                BackgroundColor="{DynamicResource CardFundoCor}"
                Padding="12,0"
                HeightRequest="{Binding AlturaCampo, Source={x:Reference this}}">
            
            <!-- Injetamos o controle interno aqui -->
            <ContentView x:Name="ContainerConteudo" />
        </Border>

        <!-- Mensagem de Erro (Visível se houver erro) -->
        <Label Text="{Binding MensagemErro, Source={x:Reference this}}"
               TextColor="{DynamicResource VermelhoCancelado}"
               FontSize="{StaticResource TamanhoTextoPequeno}"
               FontFamily="{StaticResource FontePadrao}"
               IsVisible="{Binding TemErro, Source={x:Reference this}}"
               Margin="4,0,0,0" />
    </VerticalStackLayout>
</ContentView>
