<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AgendAS.Components"
             x:Class="AgendAS.Components.CampoFormulario">

    <VerticalStackLayout Spacing="4" Margin="0,0,0,16">
        <!-- Título do Campo -->
        <Label Text="{Binding Titulo, Source={RelativeSource AncestorType={x:Type local:CampoFormulario}}}"
               Style="{StaticResource LabelSecundario}"
               FontFamily="{StaticResource FonteSemibold}"
               TextColor="{DynamicResource TextoSecundarioCor}" />

        <!-- Container do Input Customizado -->
        <Border StrokeThickness="1"
                BackgroundColor="{DynamicResource CardFundoCor}"
                Padding="12,0"
                HeightRequest="{Binding AlturaCampo, Source={RelativeSource AncestorType={x:Type local:CampoFormulario}}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Border.Stroke>
                <SolidColorBrush Color="{Binding TemErro, Source={RelativeSource AncestorType={x:Type local:CampoFormulario}}, Converter={StaticResource BooleanParaCor}}" />
            </Border.Stroke>
            
            <!-- Injetamos o controle interno aqui -->
            <ContentView x:Name="ContainerConteudo" />
        </Border>

        <!-- Mensagem de Erro (Visível se houver erro) -->
        <Label Text="{Binding MensagemErro, Source={RelativeSource AncestorType={x:Type local:CampoFormulario}}}"
               TextColor="{DynamicResource VermelhoCancelado}"
               FontSize="{StaticResource TamanhoTextoPequeno}"
               FontFamily="{StaticResource FontePadrao}"
               IsVisible="{Binding TemErro, Source={RelativeSource AncestorType={x:Type local:CampoFormulario}}}"
               Margin="4,0,0,0" />
    </VerticalStackLayout>
</ContentView>
