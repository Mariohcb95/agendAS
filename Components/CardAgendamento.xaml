<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:AgendAS.Components"
             x:Class="AgendAS.Components.CardAgendamento"
             x:Name="this">

    <Border Style="{StaticResource BorderCard}" Margin="0,0,0,8">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding ComandoToque, Source={x:Reference this}}"
                                  CommandParameter="{Binding Agendamento, Source={x:Reference this}}" />
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" RowDefinitions="Auto, Auto">
            
            <!-- Avatar Circular com Iniciais -->
            <Border Grid.RowSpan="2"
                    Grid.Column="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    BackgroundColor="{DynamicResource AzulPrimario}"
                    VerticalOptions="Center">
                
                <Label Text="{Binding Agendamento.Cliente.Iniciais, Source={x:Reference this}}"
                       TextColor="White"
                       FontFamily="{StaticResource FonteSemibold}"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- Detalhes do Cliente e Medicamento -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding Agendamento.Cliente.Nome, Source={x:Reference this}}"
                       Style="{StaticResource LabelTituloPequeno}"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Agendamento.Medicamento, Source={x:Reference this}}"
                       Style="{StaticResource LabelCorpo}"
                       TextColor="{DynamicResource AzulClaro}"
                       FontFamily="{StaticResource FonteSemibold}" />
            </VerticalStackLayout>

            <!-- Horário e Status -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="4" HorizontalOptions="End" VerticalOptions="Center">
                <Label Text="{Binding Agendamento.Hora, Source={x:Reference this}, StringFormat='{0:hh\\:mm}'}"
                       Style="{StaticResource LabelTituloPequeno}"
                       HorizontalOptions="End" />
                <components:BadgeStatus Status="{Binding Agendamento.Status, Source={x:Reference this}}" 
                                        HorizontalOptions="End"/>
            </VerticalStackLayout>

            <!-- Linha Inferior: Aplicador e Local -->
            <Grid Grid.Row="1" 
                  Grid.Column="1" 
                  Grid.ColumnSpan="2" 
                  ColumnDefinitions="*, *" 
                  ColumnSpacing="6"
                  Margin="0,6,0,0"
                  Padding="0,6,0,0">
                
                <Grid.Style>
                    <Style TargetType="Grid">
                        <!-- Adicionar linha separadora sutil superior -->
                    </Style>
                </Grid.Style>

                <!-- Aplicador -->
                <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                    <Label Text="&#xe87c;" Style="{StaticResource LabelIcone}" FontSize="14" TextColor="{DynamicResource TextoTerciarioCor}" />
                    <Label Text="{Binding Agendamento.Aplicador.Nome, Source={x:Reference this}}"
                           Style="{StaticResource LabelSecundario}"
                           LineBreakMode="TailTruncation" />
                </HorizontalStackLayout>

                <!-- Local -->
                <HorizontalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="End" VerticalOptions="Center">
                    <Label Text="&#xe0c8;" Style="{StaticResource LabelIcone}" FontSize="14" TextColor="{DynamicResource TextoTerciarioCor}" />
                    <Label Text="{Binding Agendamento.LocalAplicacao, Source={x:Reference this}}"
                           Style="{StaticResource LabelSecundario}"
                           LineBreakMode="TailTruncation" />
                </HorizontalStackLayout>
            </Grid>
        </Grid>
    </Border>
</ContentView>
