<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgendAS.Components.CardKanban"
             x:Name="this">

    <Border Style="{StaticResource BorderCard}" 
            Padding="{StaticResource PaddingCardKanban}"
            Margin="0,0,0,8"
            BackgroundColor="{DynamicResource CardFundoCor}">
        
        <Border.GestureRecognizers>
            <DragGestureRecognizer CanDrag="True" 
                                   DragStarting="OnDragStarting" />
        </Border.GestureRecognizers>

        <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="4">
            <!-- Linha 1: Cliente e Hora -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="6">
                <Label Grid.Column="0"
                       Text="{Binding Agendamento.Cliente.Nome, Source={x:Reference this}}"
                       Style="{StaticResource LabelTituloPequeno}"
                       FontSize="13"
                       LineBreakMode="TailTruncation" />
                
                <Label Grid.Column="1"
                       Text="{Binding Agendamento.Hora, Source={x:Reference this}, StringFormat='{0:hh\\:mm}'}"
                       Style="{StaticResource LabelTituloPequeno}"
                       FontSize="13"
                       TextColor="{DynamicResource AzulClaro}"
                       HorizontalOptions="End" />
            </Grid>

            <!-- Linha 2: Medicamento -->
            <Label Grid.Row="1"
                   Text="{Binding Agendamento.Medicamento, Source={x:Reference this}}"
                   Style="{StaticResource LabelCorpo}"
                   FontSize="12"
                   FontFamily="{StaticResource FonteSemibold}"
                   TextColor="{DynamicResource TextoPrimarioCor}"
                   LineBreakMode="TailTruncation" />

            <!-- Linha 3: Aplicador e Local -->
            <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="6" Margin="0,2,0,0">
                <HorizontalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="&#xe87c;" Style="{StaticResource LabelIcone}" FontSize="12" TextColor="{DynamicResource TextoTerciarioCor}" />
                    <Label Text="{Binding Agendamento.Aplicador.Nome, Source={x:Reference this}}"
                           Style="{StaticResource LabelSecundario}"
                           FontSize="11"
                           LineBreakMode="TailTruncation" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                    <Label Text="&#xe0c8;" Style="{StaticResource LabelIcone}" FontSize="12" TextColor="{DynamicResource TextoTerciarioCor}" />
                    <Label Text="{Binding Agendamento.LocalAplicacao, Source={x:Reference this}}"
                           Style="{StaticResource LabelSecundario}"
                           FontSize="11"
                           LineBreakMode="TailTruncation" />
                </HorizontalStackLayout>
            </Grid>
        </Grid>
    </Border>
</ContentView>
