<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Paleta de Cores Claras -->
    <Color x:Key="FundoClaro">#F8FAFB</Color>
    <Color x:Key="CardFundoClaro">#FFFFFF</Color>
    <Color x:Key="TextoPrimarioClaro">#0F172A</Color>
    <Color x:Key="TextoSecundarioClaro">#475569</Color>
    <Color x:Key="TextoTerciarioClaro">#94A3B8</Color>
    <Color x:Key="BordaClara">#E2E8F0</Color>
    <Color x:Key="FundoFormularioClaro">#F1F5F9</Color>

    <!-- Paleta de Cores Escuras -->
    <Color x:Key="FundoEscuro">#090D16</Color>
    <Color x:Key="CardFundoEscuro">#111827</Color>
    <Color x:Key="TextoPrimarioEscuro">#F8FAFB</Color>
    <Color x:Key="TextoSecundarioEscuro">#94A3B8</Color>
    <Color x:Key="TextoTerciarioEscuro">#475569</Color>
    <Color x:Key="BordaEscura">#1F2937</Color>
    <Color x:Key="FundoFormularioEscuro">#1F2937</Color>

    <!-- Cores de Identidade Visual (Comuns) -->
    <Color x:Key="AzulEscuroPrimario">#0A1628</Color>
    <Color x:Key="AzulPrimario">#1E3A5F</Color>
    <Color x:Key="AzulClaro">#4A90D9</Color>
    <Color x:Key="AzulAccent">#64B5F6</Color>
    
    <!-- Cores de Status (Comuns) -->
    <Color x:Key="VerdeConfirmado">#10B981</Color>
    <Color x:Key="AmareloEmAndamento">#F59E0B</Color>
    <Color x:Key="VermelhoCancelado">#EF4444</Color>
    <Color x:Key="AzulAgendado">#3B82F6</Color>
    <Color x:Key="RoxoConcluido">#8B5CF6</Color>

    <!-- Sombras e Efeitos -->
    <Color x:Key="SombraCorClara">#0D000000</Color>
    <Color x:Key="SombraCorEscura">#40000000</Color>

    <!-- Linear Gradient Brushes Concretos -->
    <LinearGradientBrush x:Key="FundoGradientePrincipal" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A1628" Offset="0.0" />
        <GradientStop Color="#1E3A5F" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FundoGradienteBotao" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1E3A5F" Offset="0.0" />
        <GradientStop Color="#4A90D9" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Cores Dinâmicas (Fallbacks Iniciais para evitar crash de DynamicResource no Android) -->
    <Color x:Key="FundoCor">#F8FAFB</Color>
    <Color x:Key="CardFundoCor">#FFFFFF</Color>
    <Color x:Key="TextoPrimarioCor">#0F172A</Color>
    <Color x:Key="TextoSecundarioCor">#475569</Color>
    <Color x:Key="TextoTerciarioCor">#94A3B8</Color>
    <Color x:Key="BordaCor">#E2E8F0</Color>
    <Color x:Key="FundoFormularioCor">#F1F5F9</Color>
    <Color x:Key="SombraCor">#0D000000</Color>

</ResourceDictionary>
