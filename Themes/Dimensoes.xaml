<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Espaçamentos -->
    <x:Double x:Key="EspacamentoXS">4</x:Double>
    <x:Double x:Key="EspacamentoS">8</x:Double>
    <x:Double x:Key="EspacamentoM">16</x:Double>
    <x:Double x:Key="EspacamentoL">24</x:Double>
    <x:Double x:Key="EspacamentoXL">32</x:Double>

    <!-- Thickness para Margins/Paddings comuns -->
    <Thickness x:Key="Margem XS">4</Thickness>
    <Thickness x:Key="Margem S">8</Thickness>
    <Thickness x:Key="Margem M">16</Thickness>
    <Thickness x:Key="Margem L">24</Thickness>
    <Thickness x:Key="Margem XL">32</Thickness>
    
    <Thickness x:Key="MargemFundo">16,16,16,16</Thickness>
    <Thickness x:Key="PaddingCard">12,12,12,12</Thickness>
    <Thickness x:Key="PaddingCardKanban">10,10,10,10</Thickness>

    <!-- Raios de Borda -->
    <CornerRadius x:Key="RaioBordaPequeno">8</CornerRadius>
    <CornerRadius x:Key="RaioBordaMedio">12</CornerRadius>
    <CornerRadius x:Key="RaioBordaGrande">16</CornerRadius>
    <CornerRadius x:Key="RaioBordaTotal">999</CornerRadius>

    <!-- Tamanhos Fixos -->
    <x:Double x:Key="AlturaBotao">48</x:Double>
    <x:Double x:Key="AlturaCampo">50</x:Double>
    <x:Double x:Key="LarguraColunaKanban">280</x:Double>

</ResourceDictionary>
