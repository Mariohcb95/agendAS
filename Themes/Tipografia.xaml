<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Configuração de Famílias de Fontes -->
    <x:String x:Key="FontePadrao">OpenSansRegular</x:String>
    <x:String x:Key="FonteSemibold">OpenSansSemibold</x:String>
    <x:String x:Key="FonteIcones">MaterialIcons</x:String>

    <!-- Tamanhos de Fonte -->
    <x:Double x:Key="TamanhoTituloGrande">24</x:Double>
    <x:Double x:Key="TamanhoTituloMedio">20</x:Double>
    <x:Double x:Key="TamanhoTituloPequeno">16</x:Double>
    <x:Double x:Key="TamanhoTextoCorpo">14</x:Double>
    <x:Double x:Key="TamanhoTextoPequeno">12</x:Double>
    <x:Double x:Key="TamanhoTextoMini">10</x:Double>

</ResourceDictionary>
