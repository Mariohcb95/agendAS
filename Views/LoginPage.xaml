<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AgendAS.ViewModels"
             xmlns:components="clr-namespace:AgendAS.Components"
             x:Class="AgendAS.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource FundoCor}">

    <!-- Grid Raiz com o background gradiente -->
    <Grid Background="{DynamicResource FundoGradientePrincipal}">
        <!-- ScrollView contendo a hierarquia de login por cima do background -->
        <ScrollView Padding="24,12">
            <VerticalStackLayout Spacing="32" 
                                 VerticalOptions="Center"
                                 HorizontalOptions="Fill"
                                 MaximumWidthRequest="450">
                
                <!-- Área Superior do Logotipo e Boas-vindas -->
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     Margin="0,32,0,0">
                    
                    <!-- Símbolo de Saúde / Premium (Material Icons) -->
                    <Border StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            HeightRequest="80"
                            WidthRequest="80"
                            BackgroundColor="#22FFFFFF"
                            HorizontalOptions="Center">
                        <Label Text="&#xe57f;" 
                               FontFamily="MaterialIcons"
                               FontSize="40"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="AgendAS"
                           TextColor="White"
                           FontFamily="{StaticResource FonteSemibold}"
                           FontSize="32"
                           HorizontalOptions="Center" />

                    <Label Text="Farmácia Premium &amp; Aplicações"
                           TextColor="{DynamicResource AzulAccent}"
                           FontFamily="{StaticResource FontePadrao}"
                           FontSize="{StaticResource TamanhoTextoCorpo}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Card Branco de Login com Slide Up e Fade -->
                <Border x:Name="LoginCard"
                        StrokeThickness="0"
                        BackgroundColor="{DynamicResource CardFundoCor}"
                        Padding="24,32,24,32"
                        TranslationY="200"
                        Opacity="0"
                        HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="16">
                        <Label Text="Acesse sua conta"
                               Style="{StaticResource LabelTituloMedio}"
                               Margin="0,0,0,8" />

                        <!-- Mensagem de Erro Geral -->
                        <Label Text="{Binding ErroLogin}"
                               TextColor="{DynamicResource VermelhoCancelado}"
                               FontSize="{StaticResource TamanhoTextoPequeno}"
                               IsVisible="{Binding ErroLogin, Converter={StaticResource StringPreenchidaParaBoolean}}"
                               HorizontalOptions="Center" />

                        <!-- Usuário -->
                        <components:CampoFormulario Titulo="Usuário"
                                                    MensagemErro="{Binding ErroUsuario}">
                            <components:CampoFormulario.Conteudo>
                                <Entry Text="{Binding NomeUsuario, Mode=TwoWay}"
                                       Placeholder="Ex: admin"
                                       Style="{StaticResource EntryCustom}" />
                            </components:CampoFormulario.Conteudo>
                        </components:CampoFormulario>

                        <!-- Senha -->
                        <components:CampoFormulario Titulo="Senha"
                                                    MensagemErro="{Binding ErroSenha}">
                            <components:CampoFormulario.Conteudo>
                                <Entry Text="{Binding Senha, Mode=TwoWay}"
                                       Placeholder="Ex: 123456"
                                       IsPassword="True"
                                       Style="{StaticResource EntryCustom}" />
                            </components:CampoFormulario.Conteudo>
                        </components:CampoFormulario>

                        <!-- Link Esqueci Minha Senha -->
                        <Label Text="Esqueceu sua senha?"
                               TextColor="{DynamicResource AzulClaro}"
                               FontFamily="{StaticResource FonteSemibold}"
                               FontSize="{StaticResource TamanhoTextoPequeno}"
                               HorizontalOptions="End"
                               Margin="0,0,0,8">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EsqueciSenhaCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <!-- Botão Entrar -->
                        <components:BotaoPrimario Texto="Acessar Sistema"
                                                  Comando="{Binding EntrarCommand}"
                                                  EstaCarregando="{Binding EstaCarregando}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
